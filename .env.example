# ═══════════════════════════════════════════════════════
# KAFIN v7.3.0 — Environment Variables
# ═══════════════════════════════════════════════════════

ENVIRONMENT=dev
USE_MOCK_DATA=false

# ── Trading Data ──────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key
FMP_API_KEY=your_fmp_key
FRED_API_KEY=your_fred_key
TAVILY_API_KEY=your_tavily_key

# ── Twelve Data — Technische Indikatoren (ADX, Stochastic, IV-Approximation)
# https://twelvedata.com → Dashboard → API Keys → Generate
# Free Tier: 800 Calls/Tag, 8/Min
# Kafin nutzt ~30-50 Calls/Tag (ADX + Stochastic, 4h Cache)
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# ── KI-Modelle ────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key
GROQ_API_KEY=gsk_...

# ── Krypto ────────────────────────────────────────────
COINGLASS_API_KEY=your_coinglass_key

# ── Alpaca Paper Trading ──────────────────────────────
# Holen unter: app.alpaca.markets → Paper Trading → API Keys → Generate New Keys
# WICHTIG: Niemals Live-Trading Keys hier eintragen
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Alpaca Market Data API (gleiche Keys wie Trading, andere URL)
# Liefert: Snapshots, Bars, Quotes für US-Aktien
# Free Tier: IEX-Daten, 15-Min-Delay — für Kafin ausreichend
ALPACA_DATA_URL=https://data.alpaca.markets
# Keys sind dieselben wie Trading:
# ALPACA_API_KEY und ALPACA_SECRET_KEY — bereits oben gesetzt

# ── Datenbank ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
POSTGRES_PASSWORD=kafin_local_dev
DATABASE_URL=postgresql://kafin:kafin_local_dev@postgres:5432/kafin

# ── Alerts ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
REDIS_URL=redis://kafin-redis:6379/0
