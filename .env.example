# FastAPI / App Settings
ENVIRONMENT=dev
# WICHTIG: KEINE MOCK DATEN ERLAUBT - IMMER ECHTE API-DATEN VERWENDEN
USE_MOCK_DATA=false

# API Keys
FINNHUB_API_KEY=your_finnhub_key_here
FMP_API_KEY=your_fmp_key_here
FRED_API_KEY=your_fred_key_here
COINGLASS_API_KEY=your_coinglass_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
# Groq API (kostenlos: console.groq.com)
# Ersetzt DeepSeek Chat für News-Extraktion
# Modell: llama-3.1-8b-instant
# 14.400 kostenlose Requests/Tag
GROQ_API_KEY=gsk_...
KIMI_API_KEY=your_kimi_key_here
TAVILY_API_KEY=your_tavily_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# PostgreSQL (lokal, Docker)
POSTGRES_PASSWORD=kafin_local_dev
DATABASE_URL=postgresql://kafin:kafin_local_dev@postgres:5432/kafin
